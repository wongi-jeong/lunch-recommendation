# docker compose 용 환경변수. 이 파일을 .env 로 복사해서 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 로 커밋되지 않습니다.

# ── 데이터베이스 (MySQL 컨테이너) ──
DB_USER=appuser
DB_PASSWORD=lunchpw
DB_ROOT_PASSWORD=rootpw

# ── Google Maps 키 (선택) ──
# 둘 다 비워두면 데모 모드로 동작합니다(샘플 식당 + 지도 미표시), 키 없이 실행 가능.
# 실제 데이터/지도를 쓰려면 값을 채우세요. (서버용/클라이언트용 키 분리 권장)
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
