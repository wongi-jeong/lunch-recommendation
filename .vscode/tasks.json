{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Spotless: Format Java Files",
			"type": "shell",
			"command": "./gradlew spotlessApply",
			"windows": {
				"command": ".\\gradlew.bat spotlessApply"
			},
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"problemMatcher": []
		}
	]
}

